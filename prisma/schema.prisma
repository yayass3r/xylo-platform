// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  directUrl         = env("DATABASE_URL_UNPOOLED")
  relationMode      = "prisma"
}

// ==================== Enums ====================

enum UserRole {
  USER
  WRITER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum ArticleStatus {
  DRAFT
  PENDING
  PUBLISHED
  REJECTED
}

enum TransactionType {
  PURCHASE          // شراء عملات
  TIP               // إرسال هدية
  WITHDRAWAL        // سحب أرباح
  REFUND            // استرداد
  REFERRAL_BONUS    // مكافأة إحالة
  ADMIN_ADJUSTMENT  // تعديل إداري
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

enum IdType {
  NATIONAL_ID
  PASSPORT
  DRIVER_LICENSE
}

enum PaymentGatewayProvider {
  STRIPE
  PAYPAL
  SKRILL
  STC_PAY
  MOYASAR
  APPLE_PAY
  GOOGLE_PAY
}

enum PaymentGatewayStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  SUSPENDED
}

enum PaymentEnvironment {
  SANDBOX
  PRODUCTION
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  DELETED
}

enum ConversationType {
  DIRECT
  GROUP
  SUPPORT
}

// === New Enums for Referral System ===

enum ReferralRewardType {
  SIGNUP_BONUS      // مكافأة التسجيل
  PURCHASE_COMMISSION // عمولة الشراء
}

enum ReferralRewardStatus {
  PENDING
  AWARDED
  CANCELLED
}

// ==================== Users ====================

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  password        String
  name            String?
  username        String?  @unique
  avatar          String?
  bio             String?
  role            UserRole @default(USER)
  status          UserStatus @default(ACTIVE)
  isEmailVerified Boolean  @default(false)
  isKycVerified   Boolean  @default(false)
  termsAcceptedAt DateTime?
  privacyAcceptedAt DateTime?
  
  // === Language Preferences ===
  preferredLanguage String @default("ar")
  timezone        String?  @default("Asia/Riyadh")
  
  // === E2EE Keys ===
  publicKey       String?  @db.Text
  privateKeyEnc   String?  @db.Text
  
  // === Referral System Fields ===
  referralCode    String   @unique            // كود الإحالة الفريد (مثال: USER_ABC123)
  referredById    String?                     // من قام بإحالة هذا المستخدم
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  articles        Article[]
  wallet          Wallet?
  sentGifts       SentGift[]  @relation("SentGiftsSender")
  receivedGifts   SentGift[]  @relation("SentGiftsReceiver")
  withdrawalRequests WithdrawalRequest[]
  kycVerification KycVerification?
  reportsMade     Report[]    @relation("ReportsMade")
  reportsReceived Report[]    @relation("ReportsReceived")
  notifications   Notification[]
  sessions        Session[]
  sentMessages    PrivateMessage[]  @relation("SentMessages")
  receivedMessages PrivateMessage[]  @relation("ReceivedMessages")
  conversations   ConversationParticipant[]
  paymentLogs     PaymentLog[]
  
  // === Referral Relations ===
  referrer        User?    @relation("Referrals", fields: [referredById], references: [id])
  referrals       User[]   @relation("Referrals")
  referralRewards ReferralReward[] @relation("ReferrerRewards")
  earnedRewards   ReferralReward[] @relation("EarnedRewards")

  @@index([email])
  @@index([username])
  @@index([preferredLanguage])
  @@index([referralCode])
}

// ==================== Articles ====================

model Article {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String   @db.Text
  excerpt     String?  @db.Text
  coverImage  String?
  authorId    String
  status      ArticleStatus @default(DRAFT)
  viewsCount  Int      @default(0)
  readTime    Int      @default(0)
  category    String?
  tags        String[] @default([])
  isFeatured  Boolean  @default(false)
  isPaid      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  publishedAt DateTime?
  language    String   @default("ar")
  translations Json?

  // Relations
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  gifts       SentGift[]
  reports     Report[]

  @@index([slug])
  @@index([authorId])
  @@index([status])
  @@index([category])
  @@index([language])
}

// ==================== Wallet ====================

model Wallet {
  id              String   @id @default(cuid())
  userId          String   @unique
  
  // === Balances ===
  coinsBalance    Int      @default(0)     // رصيد العملات (للقراء)
  diamondsBalance Int      @default(0)     // رصيد الألماس (للكتاب)
  
  // === Totals ===
  totalPurchased  Int      @default(0)     // إجمالي العملات المشتراة
  totalSpent      Int      @default(0)     // إجمالي العملات المنفقة (هدايا)
  totalEarned     Int      @default(0)     // إجمالي الألماس المكتسب
  totalWithdrawn  Int      @default(0)     // إجمالي الألماس المسحوب
  
  // === Referral Stats ===
  totalReferralEarnings Int @default(0)    // إجمالي أرباح الإحالات
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions    Transaction[]

  @@index([userId])
}

// ==================== Transactions ====================

model Transaction {
  id              String   @id @default(cuid())
  walletId        String
  type            TransactionType
  amount          Int                       // المبلغ (عملات أو ألماس)
  currency        String   @default("COINS") // COINS, DIAMONDS, USD
  status          TransactionStatus @default(PENDING)
  paymentMethod   String?
  paymentReference String?
  description     String?
  metadata        Json?
  createdAt       DateTime @default(now())
  
  // === Payment Gateway Reference ===
  gatewayId       String?
  gatewayTransactionId String?
  
  // === For Referral Transactions ===
  referralRewardId String? @unique

  // Relations
  wallet          Wallet  @relation(fields: [walletId], references: [id], onDelete: Cascade)
  referralReward  ReferralReward? @relation(fields: [referralRewardId], references: [id])

  @@index([walletId])
  @@index([type])
  @@index([status])
  @@index([gatewayId])
  @@index([createdAt])
}

// ==================== Gifts ====================

model Gift {
  id            String   @id @default(cuid())
  name          String
  nameAr        String?
  icon          String
  animation     String?
  coinCost      Int                        // تكلفة الهدية بالعملات
  diamondValue  Int                        // قيمة الهدية بالألماس (للكاتب)
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())

  // Relations
  sentGifts     SentGift[]

  @@index([isActive])
}

// ==================== Sent Gifts ====================

model SentGift {
  id          String   @id @default(cuid())
  giftId      String
  senderId    String
  receiverId  String
  articleId   String?
  message     String?
  
  // === Transactional Data (for audit) ===
  coinAmount  Int                       // عدد العملات المنزولة
  diamondAmount Int                     // عدد الألماس المضافة
  
  createdAt   DateTime @default(now())

  // Relations
  gift        Gift     @relation(fields: [giftId], references: [id])
  sender      User     @relation("SentGiftsSender", fields: [senderId], references: [id])
  receiver    User     @relation("SentGiftsReceiver", fields: [receiverId], references: [id])
  article     Article? @relation(fields: [articleId], references: [id])

  @@index([senderId])
  @@index([receiverId])
  @@index([articleId])
  @@index([createdAt])
}

// ==================== Withdrawal Requests ====================

model WithdrawalRequest {
  id              String   @id @default(cuid())
  userId          String
  
  // === Amount Details ===
  diamondAmount   Int                       // عدد الألماس المسحوب
  usdValue        Float                     // القيمة بالدولار قبل العمولة
  platformFee     Float                     // عمولة المنصة
  netAmount       Float                     // صافي المبلغ للكاتب
  
  // === Bank Details ===
  currency        String   @default("USD")
  bankName        String?
  bankAccount     String?
  accountHolderName String?
  
  // === Status ===
  status          WithdrawalStatus @default(PENDING)
  adminNotes      String?
  processedAt     DateTime?
  createdAt       DateTime @default(now())

  // Relations
  user            User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// ==================== KYC Verification ====================

model KycVerification {
  id            String   @id @default(cuid())
  userId        String   @unique
  idType        IdType
  idFrontImage  String
  idBackImage   String?
  selfieImage   String
  status        KycStatus @default(PENDING)
  adminNotes    String?
  reviewedAt    DateTime?
  createdAt     DateTime @default(now())

  // Relations
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

// ==================== Reports ====================

model Report {
  id                String   @id @default(cuid())
  reporterId        String
  reportedUserId    String?
  reportedArticleId String?
  reason            String
  description       String?  @db.Text
  status            ReportStatus @default(PENDING)
  adminNotes        String?
  reviewedBy        String?
  reviewedAt        DateTime?
  createdAt         DateTime @default(now())

  // Relations
  reporter          User      @relation("ReportsMade", fields: [reporterId], references: [id])
  reportedUser      User?     @relation("ReportsReceived", fields: [reportedUserId], references: [id])
  reportedArticle   Article?  @relation(fields: [reportedArticleId], references: [id])

  @@index([reporterId])
  @@index([reportedUserId])
  @@index([status])
}

// ==================== Notifications ====================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  content   String   @db.Text
  isRead    Boolean  @default(false)
  data      Json?
  language  String   @default("ar")
  createdAt DateTime @default(now())

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

// ==================== Coin Packages ====================

model CoinPackage {
  id        String   @id @default(cuid())
  name      String
  nameAr    String?
  coins     Int                        // عدد العملات
  price     Float                      // السعر بالدولار
  currency  String   @default("USD")
  bonus     Int      @default(0)       // عملات إضافية
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  
  // === Localized names ===
  nameEn    String?
  nameTr    String?
  nameFr    String?
  nameUr    String?

  @@index([isActive])
}

// ==================== System Settings ====================

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  description String?
  isEncrypted Boolean  @default(false)
  updatedAt   DateTime @updatedAt

  @@index([key])
}

// ==================== Sessions ====================

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  refreshToken String   @unique
  deviceInfo   String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  // Relations
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([refreshToken])
}

// ==================== Payment Gateways ====================

model PaymentGateway {
  id                String   @id @default(cuid())
  name              String   @unique
  displayName       String
  displayNameAr     String?
  provider          PaymentGatewayProvider
  status            PaymentGatewayStatus @default(INACTIVE)
  environment       PaymentEnvironment @default(SANDBOX)
  
  // === ENCRYPTED API Credentials ===
  apiKeyEnc         String   @db.Text
  apiSecretEnc      String   @db.Text
  webhookSecretEnc  String?  @db.Text
  clientIdEnc       String?  @db.Text
  clientSecretEnc   String?  @db.Text
  
  // === Configuration ===
  webhookUrl        String?
  callbackUrl       String?
  supportedCurrencies String[] @default(["USD", "SAR", "EUR"])
  supportedPaymentMethods String[] @default([])
  minAmount         Float   @default(0.5)
  maxAmount         Float   @default(10000)
  feePercentage     Float   @default(2.9)
  feeFixed          Float   @default(0.30)
  
  // === Display ===
  logo              String?
  icon              String?
  sortOrder         Int      @default(0)
  showInApp         Boolean  @default(true)
  showInWeb         Boolean  @default(true)
  
  // === Testing ===
  lastTestAt        DateTime?
  lastTestResult    String?  @db.Text
  lastTestStatus    String?
  
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  paymentLogs       PaymentLog[]

  @@index([provider])
  @@index([status])
  @@index([environment])
}

// ==================== Payment Logs ====================

model PaymentLog {
  id                String   @id @default(cuid())
  gatewayId         String
  userId            String
  
  // === Transaction details ===
  transactionType   String
  amount            Float
  currency          String
  status            String
  
  // === Coin Package Reference ===
  coinPackageId     String?
  coinsAwarded      Int?
  
  // === Gateway response ===
  gatewayTransactionId String?
  gatewayResponse   String?  @db.Text
  errorCode         String?
  errorMessage      String?
  
  // === Security ===
  ipAddress         String?
  userAgent         String?
  deviceId          String?
  
  processedAt       DateTime?
  createdAt         DateTime @default(now())

  // Relations
  gateway           PaymentGateway @relation(fields: [gatewayId], references: [id])
  user              User     @relation(fields: [userId], references: [id])

  @@index([gatewayId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// ==================== NEW: Referral Rewards ====================

model ReferralReward {
  id              String   @id @default(cuid())
  
  // === Parties ===
  referrerId      String                     // صاحب كود الإحالة (المُحيل)
  referredUserId  String                     // المستخدم المُحال
  
  // === Reward Details ===
  type            ReferralRewardType
  status          ReferralRewardStatus @default(PENDING)
  
  // === Amounts ===
  purchaseAmount  Float?                     // قيمة الشراء بالدولار (لعمولة الشراء)
  rewardCoins     Int                        // عدد العملات المكافأة
  
  // === Related Purchase ===
  paymentLogId    String?                    // مرجع عملية الشراء
  
  // === Timestamps ===
  awardedAt       DateTime?
  createdAt       DateTime @default(now())

  // Relations
  referrer        User     @relation("ReferrerRewards", fields: [referrerId], references: [id])
  referredUser    User     @relation("EarnedRewards", fields: [referredUserId], references: [id])
  transaction     Transaction?

  @@index([referrerId])
  @@index([referredUserId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

// ==================== NEW: Platform Revenue ====================

model PlatformRevenue {
  id              String   @id @default(cuid())
  
  // === Revenue Source ===
  source          String                     // "withdrawal_commission", "gift_commission"
  sourceId        String?                    // ID of the related transaction
  
  // === Amounts ===
  grossAmount     Float                      // المبلغ الإجمالي
  commissionRate  Float                       // نسبة العمولة
  netRevenue      Float                      // صافي الربح
  
  // === Currency ===
  currency        String   @default("USD")
  
  // === Timestamps ===
  createdAt       DateTime @default(now())

  @@index([source])
  @@index([createdAt])
}

// ==================== Private Messages ====================

model PrivateMessage {
  id              String   @id @default(cuid())
  conversationId  String
  senderId        String
  receiverId      String
  
  // === ENCRYPTED CONTENT ===
  contentEnc      String   @db.Text
  contentIv       String
  contentAuthTag  String
  
  // === E2EE ===
  senderKeyId     String?
  receiverKeyId   String?
  encryptedFor    String?  @db.Text
  
  // === Metadata ===
  messageType     String   @default("text")
  attachments     Json?
  replyToId       String?
  
  // === Status ===
  status          MessageStatus @default(SENT)
  editedAt        DateTime?
  deletedAt       DateTime?
  deletedFor      String[] @default([])
  
  readAt          DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime @default(now())

  // Relations
  conversation    Conversation @relation(fields: [conversationId], references: [id])
  sender          User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver        User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  replyTo         PrivateMessage? @relation("MessageReplies", fields: [replyToId], references: [id])
  replies         PrivateMessage[] @relation("MessageReplies")

  @@index([conversationId])
  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
  @@index([status])
}

// ==================== Conversations ====================

model Conversation {
  id              String   @id @default(cuid())
  type            ConversationType @default(DIRECT)
  name            String?
  nameEnc         String?
  avatar          String?
  description     String?
  lastMessageId   String?
  lastMessageAt   DateTime?
  lastMessagePreview String?
  isEncrypted     Boolean  @default(true)
  isArchived      Boolean  @default(false)
  isMuted         Boolean  @default(false)
  groupKeyEnc     String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  participants    ConversationParticipant[]
  messages        PrivateMessage[]

  @@index([type])
  @@index([lastMessageAt])
}

// ==================== Conversation Participants ====================

model ConversationParticipant {
  id              String   @id @default(cuid())
  conversationId  String
  userId          String
  keyEnc          String?  @db.Text
  unreadCount     Int      @default(0)
  lastReadAt      DateTime?
  isMuted         Boolean  @default(false)
  isArchived      Boolean  @default(false)
  role            String   @default("member")
  joinedAt        DateTime @default(now())
  leftAt          DateTime?

  // Relations
  conversation    Conversation @relation(fields: [conversationId], references: [id])
  user            User     @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
}

// ==================== Translation Keys ====================

model TranslationKey {
  id          String   @id @default(cuid())
  key         String   @unique
  namespace   String   @default("common")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  translations TranslationValue[]

  @@index([key])
  @@index([namespace])
}

// ==================== Translation Values ====================

model TranslationValue {
  id              String   @id @default(cuid())
  translationKeyId String
  language        String
  value           String   @db.Text
  isApproved      Boolean  @default(false)
  translatedBy    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  translationKey  TranslationKey @relation(fields: [translationKeyId], references: [id])

  @@unique([translationKeyId, language])
  @@index([language])
  @@index([isApproved])
}

// ==================== Encryption Audit Log ====================

model EncryptionAuditLog {
  id          String   @id @default(cuid())
  action      String
  resource    String
  resourceId  String?
  userId      String?
  ipAddress   String?
  success     Boolean  @default(true)
  errorMessage String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([action])
  @@index([resource])
  @@index([createdAt])
}
